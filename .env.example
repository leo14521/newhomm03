# =========================
# Local / Production (PostgreSQL)
# =========================

# Neon(PostgreSQL) 예시:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth (로컬)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# 디버그 필요 시만 사용
# NEXTAUTH_DEBUG="true"

# =========================
# Production (required)
# =========================
# 아래 3개는 운영 환경 변수에 반드시 설정하세요.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# NEXTAUTH_SECRET="replace-with-long-random-secret"
# NEXTAUTH_URL="https://hommageclinic.com"

# 휴대폰 인증 (개발) — 6자리 고정 코드로 테스트 (NODE_ENV=development 일 때만 적용)
# MOCK_PHONE_VERIFY_CODE="123456"
