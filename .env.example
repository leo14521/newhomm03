# 로컬 SQLite (프로젝트 루트 기준 prisma/dev.db)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth — 배포 시 반드시 강한 랜덤 문자열로 설정 (openssl rand -base64 32)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── 관리자 (/admin) 로그인 ─────────────────────────────────────────
# 아래 값으로 `npm run db:seed` 실행 시 DB에 role=ADMIN 계정이 만들어집니다.
# 로그인: 사이트 /login → 같은 이메일·비밀번호 → 헤더의 관리 또는 /admin 접속
# 로컬 예시(복사 후 .env에 넣고 시드). 운영 배포 시 반드시 강한 비밀번호로 변경하세요.
ADMIN_EMAIL="admin@hommage.local"
ADMIN_PASSWORD="HommageAdmin2025!"

# 휴대폰 인증 (개발) — 6자리 고정 코드로 테스트 (NODE_ENV=development 일 때만 적용)
# MOCK_PHONE_VERIFY_CODE="123456"
